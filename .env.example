# KineticOS Lead Magnet — Environment Variables
# Copy to .env.local for local dev (gitignored)
# Set these same vars in Vercel dashboard for production

# ── Cloudflare Worker URL ────────────────────────────────────────────────────
# Your deployed CF Worker URL (no trailing slash)
VITE_CF_WORKER_URL=https://kos-diagnostic-api.your-subdomain.workers.dev

# ── PostHog Analytics ────────────────────────────────────────────────────────
# Get from: posthog.com → Project Settings → Project API Key
VITE_POSTHOG_KEY=phc_your_posthog_project_key_here
VITE_POSTHOG_HOST=https://eu.posthog.com
